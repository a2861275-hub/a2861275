                    <li><strong>警察局 (報案)：</strong> <a href="tel:999" class="text-blue-600 underline">999</a></li>
                    <li><strong>救護車/消防局：</strong> <a href="tel:995" class="text-blue-600 underline">995</a></li>
                    <li><strong>駐星台北代表處：</strong> +65 6500 0100</li>
                    <li><strong>急難救助專線：</strong> +65 9638 9436</li>
                </ul>
            </div>

            <div class="ghibli-card p-4">
                <h3 class="font-bold text-lg text-yellow-600 mb-2"><i class="fa-solid fa-triangle-exclamation"></i> 注意事項與禁忌</h3>
                <ul class="list-disc ml-5 text-sm space-y-2 text-gray-700">
                    <li><strong>禁食口香糖：</strong> 新加坡嚴禁攜帶及販售口香糖。</li>
                    <li><strong>電子菸違法：</strong> 全面禁止攜帶及使用電子菸，抓到會重罰。</li>
                    <li><strong>大眾運輸禁食：</strong> 地鐵 (MRT) 及公車內絕對禁止飲食、喝水，違者罰款。</li>
                    <li><strong>榴槤禁令：</strong> 不可攜帶榴槤搭乘大眾運輸工具或進入部分飯店。</li>
                    <li><strong>左側通行：</strong> 新加坡手扶梯與人行道習慣靠左行駛。</li>
                </ul>
            </div>
        </section>

    </main>

    <nav class="fixed bottom-0 w-full bg-white border-t shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)] z-50 pb-safe">
        <ul class="flex justify-around items-center p-2 text-xs">
            <li class="flex-1">
                <button onclick="switchTab('plan', this)" class="nav-btn active flex flex-col items-center w-full p-2 text-ghibli-green">
                    <i class="fa-solid fa-map text-xl mb-1"></i>行程
                </button>
            </li>
            <li class="flex-1">
                <button onclick="switchTab('guide', this)" class="nav-btn flex flex-col items-center w-full p-2 text-gray-400">
                    <i class="fa-solid fa-book-open text-xl mb-1"></i>導覽
                </button>
            </li>
            <li class="flex-1">
                <button onclick="switchTab('wallet', this)" class="nav-btn flex flex-col items-center w-full p-2 text-gray-400">
                    <i class="fa-solid fa-wallet text-xl mb-1"></i>記帳
                </button>
            </li>
            <li class="flex-1">
                <button onclick="switchTab('lists', this)" class="nav-btn flex flex-col items-center w-full p-2 text-gray-400">
                    <i class="fa-solid fa-list-check text-xl mb-1"></i>清單
                </button>
            </li>
            <li class="flex-1">
                <button onclick="switchTab('info', this)" class="nav-btn flex flex-col items-center w-full p-2 text-gray-400">
                    <i class="fa-solid fa-circle-info text-xl mb-1"></i>資訊
                </button>
            </li>
        </ul>
    </nav>

    <script>
        // --- Tab Switching Logic ---
        function switchTab(tabId, btn) {
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            document.getElementById('tab-' + tabId).classList.add('active');
            
            document.querySelectorAll('.nav-btn').forEach(nav => {
                nav.classList.remove('text-ghibli-green');
                nav.classList.add('text-gray-400');
            });
            btn.classList.remove('text-gray-400');
            btn.classList.add('text-ghibli-green');
        }

        // --- Wallet Logic ---
        let currentEvalAmount = 0;
        let expenses = JSON.parse(localStorage.getItem('tripExpenses')) || [];

        function evaluateMath() {
            const input = document.getElementById('expenseCalc').value;
            try {
                // 安全的計算機取代 eval
                const result = new Function('return ' + input)();
                if(!isNaN(result) && result > 0) {
                    currentEvalAmount = result;
                    document.getElementById('calcResult').innerText = `總計: ${result} SGD`;
                }
            } catch(e) {
                alert('算式格式錯誤！請輸入如 50+20*2');
            }
        }

        async function addExpense() {
            const name = document.getElementById('expenseName').value;
            const rate = parseFloat(document.getElementById('exchangeRate').value);
            const type = document.querySelector('input[name="payType"]:checked').value;
            
            if(!name) return alert('請輸入花費品項');
            if(currentEvalAmount <= 0) return alert('請先計算金額');

            let photoBase64 = null;
            const fileInput = document.getElementById('expensePhoto');
            
            if(fileInput.files && fileInput.files[0]) {
                photoBase64 = await compressImage(fileInput.files[0]);
            }

            const item = {
                id: Date.now(),
                name,
                sgd: currentEvalAmount,
                twd: Math.round(currentEvalAmount * rate),
                type,
                photo: photoBase64,
                date: new Date().toLocaleString()
            };

            expenses.push(item);
            saveAndRenderExpenses();
            
            // Reset form
            document.getElementById('expenseName').value = '';
            document.getElementById('expenseCalc').value = '';
            currentEvalAmount = 0;
            document.getElementById('calcResult').innerText = '總計: 0 SGD';
            fileInput.value = '';
        }

        function compressImage(file) {
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onload = (event) => {
                    const img = new Image();
                    img.onload = () => {
                        const canvas = document.getElementById('photoCanvas');
                        const ctx = canvas.getContext('2d');
                        const MAX_WIDTH = 300;
                        const scaleSize = MAX_WIDTH / img.width;
                        canvas.width = MAX_WIDTH;
                        canvas.height = img.height * scaleSize;
                        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                        resolve(canvas.toDataURL('image/jpeg', 0.6));
                    };
                    img.src = event.target.result;
                };
                reader.readAsDataURL(file);
            });
        }

        function saveAndRenderExpenses() {
            localStorage.setItem('tripExpenses', JSON.stringify(expenses));
            const listDiv = document.getElementById('expenseList');
            listDiv.innerHTML = '';
            
            let cashTotal = 0;
            let cardTotal = 0;

            // 倒序顯示（新的在最上面）
            [...expenses].reverse().forEach(item => {
                if(item.type === 'cash') cashTotal += item.sgd;
                else cardTotal += item.sgd;

                const icon = item.type === 'cash' ? '💵' : '💳';
                let html = `
                    <div class="ghibli-card p-3 flex justify-between items-start">
                        <div class="flex-1">
                            <div class="font-bold text-sm">${icon} ${item.name}</div>
                            <div class="text-xs text-gray-500">${item.date}</div>
                            ${item.photo ? `<img src="${item.photo}" class="mt-2 rounded max-h-16 border">` : ''}
                        </div>
                        <div class="text-right">
                            <div class="font-bold text-ghibli-text">${item.sgd} SGD</div>
                            <div class="text-xs text-gray-400">約 NT$ ${item.twd}</div>
                        </div>
                    </div>
                `;
                listDiv.innerHTML += html;
            });

            document.getElementById('totalCash').innerText = cashTotal.toFixed(1);
            document.getElementById('totalCard').innerText = cardTotal.toFixed(1);
        }

        function clearExpenses() {
            if(confirm('確定要清除所有記帳紀錄嗎？(無法復原)')) {
                expenses = [];
                saveAndRenderExpenses();
            }
        }

        // --- Lists & Memos Logic ---
        const familyChecklist = [
            "護照 (效期需大於6個月)", "列印電子簽證/入境卡", "實體信用卡 (綁定好Apple Pay)", "備用現金 (新幣)",
            "輕便推車", "小孩換洗衣物 (多帶幾套)", "薄外套 (室內冷氣強)", "兒童防曬乳 / 防蚊液",
            "常備藥品 (退燒、腸胃、OK繃)", "濕紙巾 / 乾洗手", "空水壺 (園區裝水)", "雨具 (摺疊傘/輕便雨衣)"
        ];

        function renderChecklist() {
            const container = document.getElementById('checklistContainer');
            const savedChecks = JSON.parse(localStorage.getItem('tripChecks')) || {};
            
            familyChecklist.forEach((item, index) => {
                const isChecked = savedChecks[index] ? 'checked' : '';
                container.innerHTML += `
                    <label class="flex items-center gap-2 p-2 border-b border-gray-100 bg-white rounded mb-1">
                        <input type="checkbox" onchange="saveChecklist(${index}, this.checked)" ${isChecked} class="w-4 h-4 text-ghibli-green accent-ghibli-green">
                        <span class="${isChecked ? 'line-through text-gray-400' : ''}">${item}</span>
                    </label>
                `;
            });
        }

        function saveChecklist(index, checked) {
            const savedChecks = JSON.parse(localStorage.getItem('tripChecks')) || {};
            savedChecks[index] = checked;
            localStorage.setItem('tripChecks', JSON.stringify(savedChecks));
            // 重新渲染以更新刪除線
            document.getElementById('checklistContainer').innerHTML = '';
            renderChecklist();
        }

        function saveMemo() {
            const text = document.getElementById('memoInput').value;
            localStorage.setItem('tripMemo', text);
            renderMemo(text);
        }

        function renderMemo(text) {
            if(!text) return;
            const display = document.getElementById('memoDisplay');
            // Auto convert URLs to buttons
            const urlRegex = /(https?:\/\/[^\s]+)/g;
            const html = text.replace(urlRegex, function(url) {
                return `<a href="${url}" target="_blank" class="url-btn"><i class="fa-solid fa-link"></i> 點擊前往連結</a>`;
            });
            display.innerHTML = html;
        }

        // --- Initialization ---
        window.onload = () => {
            saveAndRenderExpenses();
            renderChecklist();
            const savedMemo = localStorage.getItem('tripMemo') || '';
            document.getElementById('memoInput').value = savedMemo;
            renderMemo(savedMemo);
        };

    </script>
</body>
</html>
